# --- Environment Files ---
.env
.env.local
.env.*.local

# --- Microservices (Laravel) ---
services/**/vendor/
services/**/.env
services/**/storage/*.key
services/**/storage/logs/*.log
services/**/storage/framework/sessions/*
services/**/storage/framework/views/*.php
services/**/storage/framework/cache/data/*
services/**/bootstrap/cache/*.php
services/**/.phpunit.result.cache

# --- Frontend (Vue/Vite) ---
frontend/web/node_modules/
frontend/web/dist/
frontend/web/.env
frontend/web/.env.local
frontend/web/npm-debug.log*
frontend/web/yarn-debug.log*
frontend/web/yarn-error.log*

# --- IDE & OS Files ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# --- Docker ---
